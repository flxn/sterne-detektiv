{
  "manifest_version": 3,

  "name": "SterneDetektiv",
  "description": "Zeigt einen korrigierten Google-Maps-Bewertungsscore inklusive entfernter Bewertungen.",
  "version": "1.0",
  "browser_specific_settings": {
      "gecko": {
          "id": "sterne-detektiv@flxn.de"
      }
  },
  "icons": {
      "32": "logo32.png",
      "64": "logo64.png",
      "256": "logo256.png"
  },

  "content_scripts": [
      {
          "matches": ["https://www.google.com/maps/*", "https://www.google.de/maps/*"],
          "css": ["content_script.css"],
          "run_at": "document_start"
      },
      {
          "matches": ["https://www.google.com/maps/*", "https://www.google.de/maps/*"],
          "js": ["js/content_script.js"],
          "run_at": "document_idle"
      }
  ],
  "web_accessible_resources": [
      {
          "resources": ["logo32.png"],
          "matches": ["https://www.google.com/*", "https://www.google.de/*"]
      }
  ]
}
